-- ========== LOGICA DE CORES ==========
local currentHue = 210
local currentBrightness = 0
local isLightMode = false

local function Color3ToHEX(color)
    local r, g, b = math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255)
    return string.format("#%02X%02X%02X", r, g, b)
end

local function HEXToColor3(hex)
    hex = hex:gsub("#", "")
    if #hex == 6 then
        return Color3.fromRGB(tonumber(hex:sub(1,2), 16), tonumber(hex:sub(3,4), 16), tonumber(hex:sub(5,6), 16))
    end
    return nil
end

local function AtualizarCores()
    local corBase = Color3.fromHSV(currentHue/360, 1, currentBrightness)
    
    if isLightMode then
        mainFrame.BackgroundColor3 = corBase:Lerp(Color3.fromRGB(255, 255, 255), 0.3)
        topBar.BackgroundColor3 = mainFrame.BackgroundColor3:Lerp(Color3.fromRGB(255, 255, 255), 0.05)
        gradientePrincipal.Enabled = true
        gradientePrincipal.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, mainFrame.BackgroundColor3),
            ColorSequenceKeypoint.new(0.6, mainFrame.BackgroundColor3:Lerp(Color3.fromRGB(0,0,0), 0.5)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(30,30,30))
        })
        topBarGradient.Enabled = true
        topBarGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, topBar.BackgroundColor3:Lerp(Color3.fromRGB(0,0,0), 0.5)),
            ColorSequenceKeypoint.new(1, topBar.BackgroundColor3)
        })
    else
        mainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        topBar.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        gradientePrincipal.Enabled = false
        topBarGradient.Enabled = false
    end
    
    -- Verifica se o toggleBtn existe antes de usar
    if _G.toggleBtn and _G.toggleBtn.Parent then 
        _G.toggleBtn.BackgroundColor3 = mainFrame.BackgroundColor3
    end
    
    if _G.hexTextBox and not _G.hexTextBox:IsFocused() then
        _G.hexTextBox.Text = Color3ToHEX(corBase)
    end
end

-- FUNÇÃO CRIAR SLIDER
local function CriarSlider(configParent, titulo, yPos, getValor, setValor, min, max)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 60, 0, 20)
    label.Position = UDim2.new(0, 10, 0, yPos)
    label.BackgroundTransparency = 1
    label.Text = titulo
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = configParent
    
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(0.75, 0, 0, 20)
    sliderFrame.Position = UDim2.new(0.2, 0, 0, yPos)
    sliderFrame.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    sliderFrame.Parent = configParent
    Instance.new("UICorner", sliderFrame).CornerRadius = UDim.new(1, 0)
    
    local sliderGradient = Instance.new("UIGradient")
    if titulo == "Cor:" then
        sliderGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.2, Color3.fromRGB(255, 255, 0)),
            ColorSequenceKeypoint.new(0.4, Color3.fromRGB(0, 255, 0)),
            ColorSequenceKeypoint.new(0.6, Color3.fromRGB(0, 255, 255)),
            ColorSequenceKeypoint.new(0.8, Color3.fromRGB(0, 0, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 255))
        })
    else
        sliderGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
        })
    end
    sliderGradient.Parent = sliderFrame
    
    local sliderButton = Instance.new("TextButton")
    sliderButton.Size = UDim2.new(0, 20, 0, 30)
    sliderButton.Position = UDim2.new((getValor() - min) / (max - min), -10, 0.5, -15)
    sliderButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderButton.Text = ""
    sliderButton.Parent = sliderFrame
    Instance.new("UICorner", sliderButton).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", sliderButton).Thickness = 2
    
    return sliderFrame, sliderButton
end

