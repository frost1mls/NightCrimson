-- LOGICA SLIDERS
local function SetupSliderLogic(frame, button, isHue)
    local dragging = false
    button.MouseButton1Down:Connect(function() dragging = true end)
    userInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    userInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local mousePos = userInputService:GetMouseLocation()
            local relativeX = math.clamp(mousePos.X - frame.AbsolutePosition.X, 0, frame.AbsoluteSize.X)
            local percent = relativeX / frame.AbsoluteSize.X
            button.Position = UDim2.new(percent, -10, 0.5, -15)
            if isHue then currentHue = percent * 360 else currentBrightness = percent end
            AtualizarCores()
        end
    end)
end
SetupSliderLogic(corSliderFrame, corSliderButton, true)
