-- Timer de inatividade (15 SEGUNDOS PARA TESTE)
local tempoInativo = 0
local tempoLimite = 15
local descansoAtivo = false
local modoDescansoHabilitado = true
local timerConnection

local function ativarDescanso()
    if not modoDescansoHabilitado or descansoAtivo then return end
    descansoAtivo = true
    telaDescanso.Visible = true
    ativarAntiAfk()
end

local function desativarDescanso()
    if not descansoAtivo then return end
    descansoAtivo = false
    telaDescanso.Visible = false
    desativarAntiAfk()
    tempoInativo = 0
end

timerConnection = runService.Heartbeat:Connect(function(deltaTime)
    if not modoDescansoHabilitado then return end
    
    if not descansoAtivo then
        tempoInativo = tempoInativo + deltaTime
        
        if tempoInativo >= tempoLimite then
            ativarDescanso()
        end
    end
end)

local function onUserInput()
    if descansoAtivo then
        desativarDescanso()
    else
        tempoInativo = 0
    end
end

userInputService.InputBegan:Connect(onUserInput)
userInputService.InputChanged:Connect(onUserInput)
localPlayer.Idled:Connect(onUserInput)

